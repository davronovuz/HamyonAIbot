# =============================================
# .env.example — bu faylni .env ga ko'chirib,
# haqiqiy qiymatlarni to'ldiring
# =============================================

# Telegram Bot (@BotFather dan olinadi)
BOT_TOKEN=your_telegram_bot_token_here
ADMINS=123456789

# PostgreSQL (docker-compose da "db" service nomi ishlatiladi)
POSTGRES_DB=hamyonai
POSTGRES_USER=hamyon
POSTGRES_PASSWORD=your_strong_password_here

# Bot DB ulanish URL — host=db (docker service nomi)
DB_URL=postgresql+asyncpg://hamyon:your_strong_password_here@db:5432/hamyonai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# pgAdmin (faqat dev profil uchun, ixtiyoriy)
PGADMIN_EMAIL=admin@hamyon.ai
PGADMIN_PASSWORD=admin

# Qarz eslatma (necha kun oldin xabar yuborilsin)
DEBT_REMINDER_DAYS=3
