# =============================================
# .env.example — bu faylni .env ga ko'chirib,
# haqiqiy qiymatlarni to'ldiring
# =============================================

# Telegram Bot (@BotFather dan olinadi)
BOT_TOKEN=your_telegram_bot_token_here
ADMINS=123456789

# PostgreSQL (docker-compose da "db" service nomi ishlatiladi)
POSTGRES_DB=hamyonai
POSTGRES_USER=hamyon
POSTGRES_PASSWORD=your_strong_password_here

# Bot DB ulanish URL — host=db (docker service nomi)
DB_URL=postgresql+asyncpg://hamyon:your_strong_password_here@db:5432/hamyonai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# ═══ Mini App (Telegram WebApp) ═══
# Telegram Mini App uchun HTTPS URL kerak.
# 80/443 portlar band bo'lsa — 3 ta variant:
#
# Variant 1: To'g'ridan-to'g'ri server IP + port 8443
#   WEBAPP_URL=https://your-server-ip:8443
#
# Variant 2: Mavjud reverse proxy orqali (subdomain)
#   WEBAPP_URL=https://hamyon.yourdomain.com
#   (nginx konfiguratsiya: nginx/site-hamyonai.conf)
#
# Variant 3: ngrok tunnel (development/test uchun)
#   ngrok http 8080
#   WEBAPP_URL=https://abc123.ngrok-free.app
#
WEBAPP_URL=

# pgAdmin (faqat dev profil uchun, ixtiyoriy)
PGADMIN_EMAIL=admin@hamyon.ai
PGADMIN_PASSWORD=admin

# Qarz eslatma (necha kun oldin xabar yuborilsin)
DEBT_REMINDER_DAYS=3
